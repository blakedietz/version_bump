//// `gen/plugin` — scaffold a new release plugin.
////
//// The Gleam analogue of a Phoenix generator (`mix phx.gen.*`). Gleam has no
//// custom-task system, so this is a normal module run via `gleam run -m`:
////
////   gleam run -m gen/plugin -- <name> --hooks <h1,h2,...> [--force]
////
//// Example:
////   gleam run -m gen/plugin -- slack --hooks verify_conditions,success
////
//// It writes `src/version_bump/plugins/<name>.gleam` and
//// `test/<name>_test.gleam`, each compiling as-is (hooks return neutral values
//// behind a `TODO`), formats them, and prints how to register the plugin.

import argv
import gleam/io
import gleam/list
import gleam/result
import gleam/string
import shellout
import simplifile

/// Every lifecycle hook the plugin contract supports.
const known_hooks = [
  "verify_conditions", "analyze_commits", "verify_release", "generate_notes",
  "add_channel", "prepare", "publish", "success", "fail",
]

pub fn main() -> Nil {
  case run(argv.load().arguments) {
    Ok(message) -> io.println(message)
    Error(message) -> io.println_error("✗ " <> message)
  }
}

fn run(args: List(String)) -> Result(String, String) {
  use #(raw_name, hooks_csv, force) <- result.try(parse_args(args))
  use selected <- result.try(validate_hooks(hooks_csv))
  let module = to_snake(raw_name)
  let spec_name = to_kebab(raw_name)
  let src_path = "src/version_bump/plugins/" <> module <> ".gleam"
  let test_path = "test/" <> module <> "_test.gleam"
  use _ <- result.try(refuse_existing(src_path, force))
  use _ <- result.try(refuse_existing(test_path, force))
  use _ <- result.try(write_file(src_path, render_plugin(spec_name, selected)))
  use _ <- result.try(write_file(test_path, render_test(module, spec_name)))
  // Best-effort formatting so the output is `gleam format`-clean.
  let _ = shellout.command("gleam", ["format", src_path, test_path], ".", [])
  Ok(success_message(module, spec_name, src_path, test_path))
}

// --- argument parsing -------------------------------------------------------

fn parse_args(args: List(String)) -> Result(#(String, String, Bool), String) {
  do_parse(args, "", "", False)
}

fn do_parse(
  args: List(String),
  name: String,
  hooks: String,
  force: Bool,
) -> Result(#(String, String, Bool), String) {
  case args {
    [] ->
      case name {
        "" -> Error(usage("missing plugin name"))
        _ -> Ok(#(name, hooks, force))
      }
    ["--force", ..rest] -> do_parse(rest, name, hooks, True)
    ["--hooks"] -> Error("--hooks requires a comma-separated value")
    ["--hooks", value, ..rest] -> do_parse(rest, name, value, force)
    [arg, ..rest] ->
      case string.starts_with(arg, "--") {
        True -> Error(usage("unknown flag: " <> arg))
        False ->
          case name {
            "" -> do_parse(rest, arg, hooks, force)
            _ -> Error("unexpected extra argument: " <> arg)
          }
      }
  }
}

fn usage(problem: String) -> String {
  problem
  <> "\nUsage: gleam run -m gen/plugin -- <name> --hooks <h1,h2,...> [--force]"
}

fn validate_hooks(csv: String) -> Result(List(String), String) {
  let selected =
    csv
    |> string.split(",")
    |> list.map(string.trim)
    |> list.filter(fn(h) { h != "" })
  case selected {
    [] ->
      Error(
        "specify at least one hook via --hooks. Known hooks: "
        <> string.join(known_hooks, ", "),
      )
    _ ->
      case list.filter(selected, fn(h) { !list.contains(known_hooks, h) }) {
        [] -> Ok(selected)
        unknown ->
          Error(
            "unknown hook(s): "
            <> string.join(unknown, ", ")
            <> ". Known hooks: "
            <> string.join(known_hooks, ", "),
          )
      }
  }
}

// --- rendering --------------------------------------------------------------

fn render_plugin(spec_name: String, selected: List(String)) -> String {
  let fields =
    selected
    |> list.map(fn(h) { "    " <> h <> ": Some(" <> h <> ")," })
    |> string.join("\n")
  let functions =
    selected
    |> list.map(hook_function)
    |> string.join("\n\n")
  string.join(
    [
      "//// The `" <> spec_name <> "` release plugin.",
      "//// Generated by `gleam run -m gen/plugin`; replace the `TODO` bodies.",
      "",
      render_imports(selected),
      "",
      "const name = \"" <> spec_name <> "\"",
      "",
      "/// Build the plugin, wiring up the implemented hooks.",
      "pub fn plugin() -> Plugin {",
      "  Plugin(",
      "    ..plugin.new(name),",
      fields,
      "  )",
      "}",
      "",
      functions,
      "",
    ],
    "\n",
  )
}

fn render_imports(selected: List(String)) -> String {
  let has = fn(h) { list.contains(selected, h) }
  let needs_option =
    has("analyze_commits") || has("add_channel") || has("publish")
  let option_symbols = case needs_option {
    True -> "type Option, None, Some"
    False -> "Some"
  }
  let base = [
    "import gleam/option.{" <> option_symbols <> "}",
    "import version_bump/config.{type PluginSpec}",
    "import version_bump/context.{type Context}",
    "import version_bump/error.{type ReleaseError}",
    "import version_bump/plugin.{type Plugin, Plugin}",
  ]
  let extra =
    [
      case has("add_channel") || has("publish") {
        True -> Ok("import version_bump/release.{type Release}")
        False -> Error(Nil)
      },
      case has("analyze_commits") {
        True -> Ok("import version_bump/semver.{type ReleaseType}")
        False -> Error(Nil)
      },
      case has("publish") {
        True -> Ok("import version_bump/task.{type Task}")
        False -> Error(Nil)
      },
    ]
    |> list.filter_map(fn(x) { x })
  string.join(list.append(base, extra), "\n")
}

/// The full source of one hook function, neutral body + a TODO.
fn hook_function(hook: String) -> String {
  case hook {
    "analyze_commits" ->
      todo_doc("inspect context.commits and return the warranted release type")
      <> sig(hook, "Result(Option(ReleaseType), ReleaseError)")
      <> "  Ok(None)\n}"
    "generate_notes" ->
      todo_doc("build the release notes markdown for context.next_release")
      <> sig(hook, "Result(String, ReleaseError)")
      <> "  Ok(\"\")\n}"
    "add_channel" ->
      todo_doc("add the existing release to a dist channel")
      <> sig(hook, "Result(Option(Release), ReleaseError)")
      <> "  Ok(None)\n}"
    "publish" ->
      todo_doc("publish the release; wrap synchronous work in task.resolve")
      <> sig(hook, "Task(Result(Option(Release), ReleaseError))")
      <> "  task.resolve(Ok(None))\n}"
    // verify_conditions / verify_release / prepare / success / fail
    _ ->
      todo_doc(effect_hint(hook))
      <> sig(hook, "Result(Nil, ReleaseError)")
      <> "  Ok(Nil)\n}"
  }
}

fn sig(hook: String, return_type: String) -> String {
  "fn "
  <> hook
  <> "(_spec: PluginSpec, _context: Context) -> "
  <> return_type
  <> " {\n"
}

fn todo_doc(text: String) -> String {
  "/// TODO: " <> text <> ".\n"
}

fn effect_hint(hook: String) -> String {
  case hook {
    "verify_conditions" ->
      "verify auth/files are present (Error(PluginError(name, ...)) to abort)"
    "verify_release" -> "verify the release that is about to be made"
    "prepare" -> "prepare the release (e.g. write files under context.cwd)"
    "success" -> "run after a successful release (notify, comment)"
    "fail" -> "run after a failed release (notify)"
    _ -> "implement this hook"
  }
}

fn render_test(module: String, spec_name: String) -> String {
  string.join(
    [
      "import gleeunit",
      "import gleeunit/should",
      "import version_bump/plugins/" <> module,
      "",
      "pub fn main() {",
      "  gleeunit.main()",
      "}",
      "",
      "pub fn " <> module <> "_registers_under_its_name_test() {",
      "  " <> module <> ".plugin().name",
      "  |> should.equal(\"" <> spec_name <> "\")",
      "}",
      "",
    ],
    "\n",
  )
}

fn success_message(
  module: String,
  spec_name: String,
  src_path: String,
  test_path: String,
) -> String {
  string.join(
    [
      "✓ created " <> src_path,
      "✓ created " <> test_path,
      "",
      "Next steps:",
      "  1. Register it in src/version_bump/registry.gleam:",
      "       import version_bump/plugins/" <> module,
      "       // ...then add to default()'s list:",
      "       #(\"" <> spec_name <> "\", " <> module <> ".plugin()),",
      "  2. Fill in the TODO hook bodies in " <> src_path,
      "  3. gleam build && gleam test",
    ],
    "\n",
  )
}

// --- helpers ----------------------------------------------------------------

fn to_snake(s: String) -> String {
  s |> string.lowercase |> string.replace("-", "_")
}

fn to_kebab(s: String) -> String {
  s |> string.lowercase |> string.replace("_", "-")
}

fn refuse_existing(path: String, force: Bool) -> Result(Nil, String) {
  case force {
    True -> Ok(Nil)
    False ->
      case simplifile.is_file(path) {
        Ok(True) -> Error(path <> " already exists (use --force to overwrite)")
        _ -> Ok(Nil)
      }
  }
}

fn write_file(path: String, contents: String) -> Result(Nil, String) {
  simplifile.write(to: path, contents: contents)
  |> result.map_error(fn(e) {
    "could not write " <> path <> ": " <> simplifile.describe_error(e)
  })
}
